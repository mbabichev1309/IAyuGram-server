# Telegram API credentials — get from https://my.telegram.org (API development tools)
API_ID=0
API_HASH=

# Session string for the 2nd authorized session.
# Generate once with:  python scripts/login.py
SESSION_STRING=

# Fernet key for encrypting stored message content at rest.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONTENT_KEY=

# Local API bind (client pulls via REST gap-sync + WebSocket live)
HOST=0.0.0.0
PORT=8787

# Shared secret the iOS client sends to authenticate to this server
CLIENT_TOKEN=change-me

# SQLite file (content store + event log + pts)
DB_PATH=data/iayugram.db

# Rolling content-store retention (hours). Older non-deleted content is pruned.
CONTENT_RETENTION_HOURS=168
